# mermaid-rs-remote-renderer — operator config reference.
#
# Copy to `.env` next to docker-compose.yml, or feed the variables into any
# orchestrator. Every variable also has an equivalent CLI flag — run
# `mermaid-rs-remote-renderer --help` for the canonical list. CLI flags win
# when both are set. Values shown below are the defaults; only set the ones
# you want to override.

# --- HTTP server -----------------------------------------------------------

# TCP socket the server binds. Use 0.0.0.0:3000 inside containers.
MMDR_BIND=0.0.0.0:3000

# Reject request bodies larger than this many bytes. Mermaid sources are
# tiny, so 64 KiB is generous.
MMDR_MAX_BODY_BYTES=65536

# --- Rate limiting (per-IP token bucket) -----------------------------------

# Requests-per-minute replenish rate. 0 disables rate limiting entirely.
MMDR_RPM=60

# Burst size — back-to-back requests an IP may issue before throttling
# kicks in.
MMDR_BURST=20

# Trust X-Forwarded-For / X-Real-IP / Forwarded for client IP. Set to
# "true" ONLY when running behind a reverse proxy you control — otherwise
# clients can spoof their IP and bypass per-IP rate limiting.
MMDR_TRUST_FORWARDED_FOR=false

# --- Concurrency + timeouts ------------------------------------------------

# Global cap on in-flight renders. Excess requests get HTTP 503 (load shed).
# 0 disables the cap.
MMDR_MAX_CONCURRENT=16

# Hard deadline for the synchronous render call. Exceeding it returns 504.
MMDR_RENDER_TIMEOUT_SECS=10

# Hard deadline for the entire HTTP request lifecycle. Should be ≥ the
# render timeout to leave room for decode + response build.
MMDR_REQUEST_TIMEOUT_SECS=15

# --- Auth (optional) -------------------------------------------------------

# When set, every /svg/* request must carry this token in the X-Api-Token
# header or ?token= query param. /health and / are always public. Empty
# string is treated as unset, so MMDR_API_TOKEN= reliably disables the gate
# without removing the variable.
# MMDR_API_TOKEN=change-me

# --- Logging ---------------------------------------------------------------

# tracing-subscriber filter. For verbose request logs, try:
#   RUST_LOG=mermaid_rs_remote_renderer=debug,tower_http=debug
RUST_LOG=info

# --- docker-compose only ---------------------------------------------------

# Image tag docker-compose pulls. Override to a SHA-pinned tag if you don't
# want to track :latest.
# MMDR_IMAGE=ghcr.io/moarster/mermaid-rs-remote-renderer:latest
